<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- 悬浮球图标 -->
    <com.example.philotes.ui.AiStateOrbView
        android:id="@+id/floating_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="8dp"
        android:background="@drawable/bg_floating_orb"
        android:elevation="8dp"
        android:contentDescription="Snap Button" />

    <!-- 结果卡片 (默认隐藏) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_result"
        android:layout_width="300dp"
        android:layout_height="320dp"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:cardCornerRadius="18dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@drawable/bg_floating_card">

            <!-- 拖拽把手区域（可拖动卡片） -->
            <LinearLayout
                android:id="@+id/card_drag_handle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="12dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp">

                <com.example.philotes.ui.AiStateOrbView
                    android:id="@+id/aiStateOrb"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="智能解析结果"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:textColor="#4A5F84" />

                <!-- 拖动提示图标 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⠿"
                    android:textSize="16sp"
                    android:textColor="#BEC8D8"
                    android:paddingStart="4dp" />

            </LinearLayout>

            <!-- 多计划导航栏（单个计划时隐藏） -->
            <LinearLayout
                android:id="@+id/layout_plan_nav"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btn_prev_plan"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="◀"
                    android:textSize="14sp"
                    android:textColor="#355A90"
                    android:padding="6dp" />

                <TextView
                    android:id="@+id/tv_plan_indicator"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1 / 1"
                    android:textSize="12sp"
                    android:textColor="#5A6F8F"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/btn_next_plan"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="▶"
                    android:textSize="14sp"
                    android:textColor="#355A90"
                    android:padding="6dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EBF0FA"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- 可滚动内容区 -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:scrollbars="vertical"
                android:fadeScrollbars="false">

                <TextView
                    android:id="@+id/tv_card_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="正在分析..."
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="3dp"
                    android:textColor="#0E1C36"
                    android:paddingBottom="8dp" />

            </ScrollView>

            <!-- 操作按钮栏 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="14dp">

                <Button
                    android:id="@+id/btn_action"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="执行"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_primary"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="清除"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#355B95"
                    android:background="@drawable/bg_button_ghost"
                    android:layout_marginEnd="8dp" />

                <ImageButton
                    android:id="@+id/btn_close_card"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_button_ghost"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#355B95"
                    android:scaleType="centerInside"
                    android:contentDescription="Close" />

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
